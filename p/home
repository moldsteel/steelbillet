*{box-sizing:border-box;margin:0;padding:0}
:root{
  --g:#1A7A4A;--gd:#0f5533;--gl:#e8f5ee;--g2:#6ee7a0;
  --gold:#c8971a;--goldbg:#fdf6e3;
  --bg:#f7f8f6;--card:#fff;--bd:#e5e7eb;
  --t1:#111827;--t2:#4b5563;--t3:#9ca3af;
  --r:12px;
}
html{scroll-behavior:smooth}
body{font-family:"Comfortaa",sans-serif;background:var(--bg);color:var(--t1);line-height:1.6}
a{text-decoration:none;color:inherit}

.nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:14px 40px;background:rgba(15,85,51,0.96);backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,255,255,.08);transition:all .3s}
.nav-logo{display:flex;align-items:center;gap:11px}
.nav-logo-box{width:38px;height:38px;border-radius:9px;background:var(--g);display:flex;align-items:center;justify-content:center;font-size:18px;box-shadow:0 4px 12px #1a7a4a55}
.nav-brand{color:#fff;font-weight:700;font-size:13.5px;line-height:1.25}
.nav-brand small{display:block;font-size:9.5px;font-weight:400;opacity:.6;letter-spacing:1.8px;text-transform:uppercase}
.nav-links{display:flex;align-items:center;gap:24px}
.nav-links a{color:rgba(255,255,255,.75);font-size:12.5px;font-weight:500;transition:color .2s}
.nav-links a:hover{color:#fff}
.nav-call{display:inline-flex;align-items:center;gap:7px;padding:8px 18px;border-radius:99px;background:var(--g);color:#fff;font-size:12.5px;font-weight:700;box-shadow:0 4px 14px #1a7a4a55;transition:all .2s}
.nav-call:hover{background:#22a05e;transform:translateY(-1px)}
.nav-call svg{width:13px;height:13px}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px}
.hamburger span{width:22px;height:2px;background:#fff;border-radius:2px;transition:all .3s}
.mobile-menu{display:none;position:fixed;inset:0;top:66px;background:var(--gd);z-index:99;padding:24px;flex-direction:column;gap:0}
.mobile-menu a{display:block;padding:16px 0;color:rgba(255,255,255,.85);font-size:15px;font-weight:600;border-bottom:1px solid rgba(255,255,255,.08)}
.mobile-menu.open{display:flex}

.hero{min-height:calc(100 * min(var(--vh,1vh),1vh));background:var(--gd);display:flex;flex-direction:column;position:relative;overflow:hidden;padding-top:66px}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 70% at 65% 25%,#2a9d6422,transparent 65%),radial-gradient(ellipse 50% 60% at 5% 75%,#0f553355,transparent 55%)}
.hero::after{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);background-size:36px 36px}
.hero-body{position:relative;z-index:2;flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:64px 24px 56px}
.hero-pill{display:inline-flex;align-items:center;gap:8px;padding:6px 16px;border-radius:99px;border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.07);color:rgba(255,255,255,.82);font-size:11.5px;backdrop-filter:blur(10px);margin-bottom:26px;animation:up .5s both}
.blink{width:7px;height:7px;border-radius:50%;background:var(--g2);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 #6ee7a066}50%{box-shadow:0 0 0 6px #6ee7a000}}
.hero-h1{font-family:"DM Serif Display",serif;font-size:clamp(36px,6.5vw,68px);color:#fff;line-height:1.1;margin-bottom:18px;animation:up .5s .08s both}
.hero-h1 em{color:var(--g2);font-style:italic}
.hero-p{font-size:clamp(13px,1.8vw,16px);color:rgba(255,255,255,.68);max-width:560px;margin:0 auto 18px;animation:up .5s .14s both}
.hero-tags{display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-bottom:38px;animation:up .5s .2s both}
.hero-tag{padding:5px 12px;border-radius:99px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.14);color:rgba(255,255,255,.78);font-size:11px;backdrop-filter:blur(8px)}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;animation:up .5s .26s both}
.btn-w{padding:13px 28px;border-radius:99px;background:#fff;color:var(--gd);font-size:13.5px;font-weight:700;display:inline-flex;align-items:center;gap:8px;box-shadow:0 8px 24px rgba(0,0,0,.22);transition:all .2s}
.btn-w:hover{transform:translateY(-2px);box-shadow:0 12px 32px rgba(0,0,0,.32)}
.btn-o{padding:13px 28px;border-radius:99px;border:1.5px solid rgba(255,255,255,.3);color:#fff;font-size:13.5px;font-weight:600;display:inline-flex;align-items:center;gap:8px;transition:all .2s}
.btn-o:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.6)}
.btn-w svg,.btn-o svg{width:15px;height:15px}
.hero-stats{position:relative;z-index:2;display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid rgba(255,255,255,.09);background:rgba(0,0,0,.28);backdrop-filter:blur(20px)}
.hs{padding:22px 16px;text-align:center;border-right:1px solid rgba(255,255,255,.07)}
.hs:last-child{border:none}
.hs-n{font-size:clamp(20px,3.5vw,32px);font-weight:700;color:var(--g2);line-height:1}
.hs-l{font-size:10px;color:rgba(255,255,255,.5);margin-top:5px;text-transform:uppercase;letter-spacing:1.5px}
@keyframes up{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}

section{padding:80px 0}
.wrap{max-width:1160px;margin:0 auto;padding:0 24px}
.sec-tag{display:inline-block;padding:3px 13px;border-radius:99px;background:var(--gl);color:var(--g);font-size:10.5px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:12px}
.sec-h{font-family:"DM Serif Display",serif;font-size:clamp(24px,3.8vw,40px);color:var(--t1);line-height:1.2;margin-bottom:12px}
.sec-p{font-size:14.5px;color:var(--t2);max-width:540px;line-height:1.75}
.reveal{opacity:0;transform:translateY(28px);transition:all .55s ease}
.reveal.vis{opacity:1;transform:none}
.d1{transition-delay:.08s}.d2{transition-delay:.16s}.d3{transition-delay:.24s}.d4{transition-delay:.32s}

#about{background:#fff}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.about-feats{display:flex;flex-direction:column;gap:14px;margin-top:28px}
.af{display:flex;align-items:flex-start;gap:14px;padding:16px 18px;border-radius:10px;border:1px solid var(--bd);background:var(--bg);transition:all .2s}
.af:hover{border-color:var(--g);box-shadow:0 4px 18px #1a7a4a0e}
.af-icon{width:38px;height:38px;border-radius:9px;background:var(--gl);color:var(--g);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.af-t{font-size:13.5px;font-weight:700;margin-bottom:3px}
.af-d{font-size:12.5px;color:var(--t2);line-height:1.55}
.av{background:linear-gradient(140deg,var(--gd) 0%,#1a5c37 100%);border-radius:18px;padding:40px 36px;color:#fff;box-shadow:0 24px 56px #1a7a4a2e;position:relative;overflow:hidden}
.av::before{content:'';position:absolute;top:-50px;right:-50px;width:180px;height:180px;border-radius:50%;background:rgba(255,255,255,.04)}
.av::after{content:'';position:absolute;bottom:-60px;left:-30px;width:150px;height:150px;border-radius:50%;background:rgba(255,255,255,.04)}
.av-label{font-size:9.5px;letter-spacing:2.5px;text-transform:uppercase;opacity:.55;margin-bottom:7px}
.av-title{font-family:"DM Serif Display",serif;font-size:26px;line-height:1.25;margin-bottom:26px}
.av-row{display:flex;align-items:center;gap:11px;padding:11px 14px;border-radius:9px;background:rgba(255,255,255,.08);font-size:12.5px;margin-bottom:10px;position:relative;z-index:2}
.av-row:last-child{margin:0}
.av-row svg{width:16px;height:16px;color:var(--g2);flex-shrink:0}

#products{background:var(--bg)}
.prod-head{text-align:center;margin-bottom:48px}
.prod-head .sec-p{margin:0 auto}
.cats{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
.cat{border-radius:var(--r);border:1px solid var(--bd);background:var(--card);overflow:hidden;transition:all .25s}
.cat:hover{transform:translateY(-3px);box-shadow:0 14px 40px rgba(0,0,0,.09);border-color:transparent}
.cat-head{padding:24px 24px 18px;border-bottom:1px solid var(--bd)}
.cat-icon-wrap{display:flex;align-items:center;gap:14px;margin-bottom:14px}
.cat-icon{width:48px;height:48px;border-radius:13px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0}
.cat-name{font-size:16px;font-weight:700;line-height:1.2}
.cat-sub{font-size:12px;color:var(--t2);margin-top:3px}
.cat-desc{font-size:12.5px;color:var(--t2);line-height:1.6}
.cat-body{padding:18px 24px 22px}
.grades-wrap{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px}
.grade{padding:5px 11px;border-radius:8px;font-size:12px;font-weight:700;border:1px solid;white-space:nowrap}
.size-rows{display:flex;flex-direction:column;gap:6px}
.size-row{display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:8px;font-size:11.5px}
.size-icon{font-size:14px;flex-shrink:0}
.size-label{font-weight:700;white-space:nowrap}
.size-val{color:var(--t2)}

.cat-plastic .cat:hover{box-shadow:0 14px 40px #16a34a18}
.cat-plastic .cat-head{background:linear-gradient(135deg,#f0fdf4,#dcfce7)}
.cat-plastic .cat-icon{background:#bbf7d0;color:#15803d}
.cat-plastic .cat-name{color:#14532d}
.cat-plastic .grade{background:#f0fdf4;color:#166534;border-color:#bbf7d0}
.cat-plastic .size-row{background:#f0fdf4}

.cat-cold .cat:hover{box-shadow:0 14px 40px #1d4ed818}
.cat-cold .cat-head{background:linear-gradient(135deg,#eff6ff,#dbeafe)}
.cat-cold .cat-icon{background:#bfdbfe;color:#1d4ed8}
.cat-cold .cat-name{color:#1e3a8a}
.cat-cold .grade{background:#eff6ff;color:#1d4ed8;border-color:#bfdbfe}
.cat-cold .size-row{background:#eff6ff}

.cat-hot .cat:hover{box-shadow:0 14px 40px #c2410c18}
.cat-hot .cat-head{background:linear-gradient(135deg,#fff7ed,#fed7aa)}
.cat-hot .cat-icon{background:#fed7aa;color:#c2410c}
.cat-hot .cat-name{color:#7c2d12}
.cat-hot .grade{background:#fff7ed;color:#c2410c;border-color:#fed7aa}
.cat-hot .size-row{background:#fff7ed}

.cat-carbon .cat:hover{box-shadow:0 14px 40px #37415118}
.cat-carbon .cat-head{background:linear-gradient(135deg,#f9fafb,#f3f4f6)}
.cat-carbon .cat-icon{background:#e5e7eb;color:#374151}
.cat-carbon .cat-name{color:#111827}
.cat-carbon .grade{background:#f3f4f6;color:#374151;border-color:#e5e7eb}
.cat-carbon .size-row{background:#f9fafb}

.cat-alu .cat:hover{box-shadow:0 14px 40px #b4530018}
.cat-alu .cat-head{background:linear-gradient(135deg,#fefce8,#fef08a)}
.cat-alu .cat-icon{background:#fde68a;color:#92400e}
.cat-alu .cat-name{color:#713f12}
.cat-alu .grade{background:#fefce8;color:#92400e;border-color:#fde68a}
.cat-alu .size-row{background:#fefce8}

.cat-copper .cat:hover{box-shadow:0 14px 40px #c2410c18}
.cat-copper .cat-head{background:linear-gradient(135deg,#fff3e0,#ffe0b2)}
.cat-copper .cat-icon{background:#ffcc80;color:#bf360c}
.cat-copper .cat-name{color:#bf360c}
.cat-copper .grade{background:#fff3e0;color:#bf360c;border-color:#ffcc80}
.cat-copper .size-row{background:#fff3e0}

#services{background:#fff}
.svc-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px;margin-top:40px}
.svc{padding:24px 22px;border-radius:var(--r);border:1px solid var(--bd);transition:all .2s}
.svc:hover{border-color:var(--g);box-shadow:0 6px 24px #1a7a4a0e;transform:translateY(-2px)}
.svc-ico{font-size:28px;margin-bottom:12px}
.svc-t{font-size:14px;font-weight:700;margin-bottom:6px}
.svc-d{font-size:12.5px;color:var(--t2);line-height:1.6}

#contact{background:var(--gd);position:relative;overflow:hidden}
#contact::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);background-size:30px 30px}
.contact-wrap{position:relative;z-index:2;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start}
.cl .sec-tag{background:rgba(255,255,255,.12);color:rgba(255,255,255,.8)}
.cl .sec-h{color:#fff}
.cl .sec-p{color:rgba(255,255,255,.62)}
.chips{display:flex;flex-wrap:wrap;gap:9px;margin-top:22px}
.chip{padding:8px 14px;border-radius:99px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.72);font-size:11.5px}
.ccard{background:rgba(255,255,255,.07);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.12);border-radius:18px;padding:32px;display:flex;flex-direction:column;gap:16px}
.ci{display:flex;align-items:center;gap:14px;padding:14px 18px;border-radius:11px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.07);transition:all .2s}
.ci:hover{background:rgba(255,255,255,.11);border-color:rgba(255,255,255,.18)}
.ci-ico{width:44px;height:44px;border-radius:11px;background:var(--g);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 4px 12px #1a7a4a55}
.ci-ico svg{width:20px;height:20px;color:#fff}
.ci-l{font-size:10px;color:rgba(255,255,255,.45);letter-spacing:1px;text-transform:uppercase;margin-bottom:3px}
.ci-v{font-size:16px;font-weight:700;color:#fff}
.ci-v a{color:#fff}
.ci-v a:hover{color:var(--g2)}
.cta-btn{display:flex;align-items:center;justify-content:center;gap:10px;padding:15px;border-radius:11px;background:var(--g);color:#fff;font-size:15px;font-weight:700;box-shadow:0 6px 20px #1a7a4a55;transition:all .2s}
.cta-btn:hover{background:#22a05e;transform:translateY(-2px);box-shadow:0 10px 28px #1a7a4a77}
.cta-btn svg{width:20px;height:20px}

footer{background:#081f0f;padding:24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.ft-l{font-size:12.5px;color:rgba(255,255,255,.45)}
.ft-l strong{color:rgba(255,255,255,.75)}
.ft-r{font-size:11px;color:rgba(255,255,255,.28)}

@media(max-width:900px){
  .cats{grid-template-columns:1fr}
  .about-grid{grid-template-columns:1fr;gap:32px}
  .contact-wrap{grid-template-columns:1fr}
  .hero-stats{grid-template-columns:repeat(2,1fr)}
  .hs:nth-child(2){border-right:none}
}
@media(max-width:640px){
  .nav{padding:12px 18px}
  .nav-links{display:none}
  .hamburger{display:flex}
  .hero-stats{grid-template-columns:1fr 1fr}
  .hs{padding:16px 10px}
}
@media(max-width:420px){
  .hero-stats{grid-template-columns:1fr}
  .hs{border-right:none;border-bottom:1px solid rgba(255,255,255,.07)}
}
</style>
