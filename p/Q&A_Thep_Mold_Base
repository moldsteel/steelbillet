        <tr><td>S55C</td><td>1055</td><td>C55 / 1.1203</td><td>55#</td><td>Tấm chịu lực cao hơn</td></tr>
        <tr><td>SS400</td><td>A36 (gần đúng)</td><td>S235JR</td><td>Q235</td><td>Khung, tấm chặn, kết cấu phụ</td></tr>
