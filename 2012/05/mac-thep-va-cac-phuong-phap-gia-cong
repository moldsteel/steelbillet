
<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{font-family:'Open Sans',sans-serif;box-sizing:border-box}
h2.sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)}
.wrap{padding:12px 0}
.filter-section{margin-bottom:10px}
.filter-label{font-size:10px;font-weight:700;color:var(--color-text-secondary);letter-spacing:.07em;text-transform:uppercase;margin-bottom:5px}
.filter-bar{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:4px}
.fbtn{background:var(--color-background-secondary);border:1px solid var(--color-border-secondary);color:var(--color-text-secondary);border-radius:20px;padding:3px 11px;font-size:11px;font-weight:600;cursor:pointer;transition:all .15s;font-family:'Open Sans',sans-serif;white-space:nowrap}
.fbtn:hover{border-color:var(--color-border-primary)}
.fbtn.active-src{background:var(--color-text-primary);color:var(--color-background-primary);border-color:var(--color-text-primary)}
.fbtn.active-gc.gc-cnc {background:#E6F1FB;color:#0C447C;border-color:#378ADD}
.fbtn.active-gc.gc-cut {background:#EAF3DE;color:#27500A;border-color:#639922}
.fbtn.active-gc.gc-edm {background:#EEEDFE;color:#3C3489;border-color:#7F77DD}
.fbtn.active-gc.gc-grnd{background:#FAEEDA;color:#633806;border-color:#BA7517}
.fbtn.active-gc.gc-ht  {background:#FCEBEB;color:#791F1F;border-color:#E24B4A}
.fbtn.active-gc.gc-weld{background:#E1F5EE;color:#085041;border-color:#1D9E75}
.fbtn.active-gc.gc-prec{background:#FBEAF0;color:#72243E;border-color:#D4537E}
@media(prefers-color-scheme:dark){
  .fbtn.active-gc.gc-cnc {background:#0C447C;color:#B5D4F4;border-color:#378ADD}
  .fbtn.active-gc.gc-cut {background:#27500A;color:#C0DD97;border-color:#639922}
  .fbtn.active-gc.gc-edm {background:#3C3489;color:#CECBF6;border-color:#7F77DD}
  .fbtn.active-gc.gc-grnd{background:#633806;color:#FAC775;border-color:#BA7517}
  .fbtn.active-gc.gc-ht  {background:#791F1F;color:#F7C1C1;border-color:#E24B4A}
  .fbtn.active-gc.gc-weld{background:#085041;color:#9FE1CB;border-color:#1D9E75}
  .fbtn.active-gc.gc-prec{background:#72243E;color:#F4C0D1;border-color:#D4537E}
}
.divider{border:none;border-top:1px solid var(--color-border-tertiary);margin:8px 0}
table{width:100%;border-collapse:collapse}
thead th{font-size:11px;font-weight:600;color:var(--color-text-secondary);text-align:left;padding:6px 8px;border-bottom:1.5px solid var(--color-border-primary);white-space:nowrap}
tbody tr{border-bottom:1px solid var(--color-border-tertiary)}
tbody tr:last-child{border-bottom:none}
td{padding:6px 8px;vertical-align:middle}
.mac{font-weight:600;color:var(--color-text-primary);white-space:nowrap;font-size:13px}
.shape{font-size:11px;color:var(--color-text-secondary)}
.group-hdr{background:var(--color-background-secondary)}
.group-hdr td{font-size:11px;font-weight:600;color:var(--color-text-secondary);padding:5px 8px;letter-spacing:.05em;text-transform:uppercase}
.badge{display:inline-flex;align-items:center;border-radius:4px;padding:2px 6px;font-size:10px;font-weight:600;margin:2px 2px 2px 0;white-space:nowrap}
.b-cnc {background:#E6F1FB;color:#0C447C}
.b-cut {background:#EAF3DE;color:#27500A}
.b-edm {background:#EEEDFE;color:#3C3489}
.b-grnd{background:#FAEEDA;color:#633806}
.b-ht  {background:#FCEBEB;color:#791F1F}
.b-weld{background:#E1F5EE;color:#085041}
.b-prec{background:#FBEAF0;color:#72243E}
@media(prefers-color-scheme:dark){
  .b-cnc {background:#0C447C;color:#B5D4F4}
  .b-cut {background:#27500A;color:#C0DD97}
  .b-edm {background:#3C3489;color:#CECBF6}
  .b-grnd{background:#633806;color:#FAC775}
  .b-ht  {background:#791F1F;color:#F7C1C1}
  .b-weld{background:#085041;color:#9FE1CB}
  .b-prec{background:#72243E;color:#F4C0D1}
}
.src-atp{background:#1D9E75;color:#fff;border-radius:6px;font-size:10px;padding:3px 8px;font-weight:600;white-space:nowrap}
.src-vn {background:#378ADD;color:#fff;border-radius:6px;font-size:10px;padding:2px 7px;font-weight:600;white-space:nowrap}
.src-cn {background:#E24B4A;color:#fff;border-radius:6px;font-size:10px;padding:2px 7px;font-weight:600;white-space:nowrap}
.src-int{background:#888780;color:#fff;border-radius:6px;font-size:10px;padding:2px 7px;font-weight:600;white-space:nowrap}
.note{font-size:11px;color:var(--color-text-secondary)}
tr.hidden{display:none}
.stat{margin-top:10px;font-size:11px;color:var(--color-text-secondary)}
.stat strong{font-weight:600}
.no-result{text-align:center;padding:24px;font-size:13px;color:var(--color-text-secondary);display:none}
/* price card */
.card{background:var(--color-background-primary);border:1px solid var(--color-border-tertiary);border-radius:12px;overflow:hidden;margin:18px 0 4px}
.card-header{background:#1D9E75;padding:14px 20px}
.card-header h2{margin:0;font-size:15px;font-weight:700;color:#fff}
.card-header span{font-size:12px;color:rgba(255,255,255,.8)}
.sections{display:grid;grid-template-columns:1fr 1fr;gap:0}
@media(max-width:520px){.sections{grid-template-columns:1fr}}
.section{padding:16px 20px;border-right:1px solid var(--color-border-tertiary)}
.section:last-child{border-right:none}
.sec-title{display:flex;align-items:center;gap:7px;font-size:12px;font-weight:700;color:var(--color-text-secondary);letter-spacing:.06em;text-transform:uppercase;margin-bottom:12px}
.price-row{display:flex;justify-content:space-between;align-items:baseline;padding:7px 0;border-bottom:1px solid var(--color-border-tertiary)}
.price-row:last-child{border-bottom:none}
.pr-label{font-size:13px;font-weight:500;color:var(--color-text-primary)}
.pr-price{font-size:13px;font-weight:700;color:#1D9E75;white-space:nowrap;margin-left:12px}
.pr-price.quote{color:var(--color-text-secondary);font-weight:500;font-style:italic;font-size:12px}
.notes{background:var(--color-background-secondary);border-top:1px solid var(--color-border-tertiary);padding:12px 20px;display:flex;flex-direction:column;gap:5px}
.note-row{display:flex;align-items:flex-start;gap:7px;font-size:11.5px;color:var(--color-text-secondary);line-height:1.5}
.note-dot{color:#1D9E75;font-weight:700;flex-shrink:0}
.footer-bar{background:var(--color-background-secondary);border-top:1px solid var(--color-border-tertiary);padding:8px 20px;display:flex;flex-wrap:wrap;gap:6px;align-items:center}
.ftag{display:inline-flex;align-items:center;gap:4px;font-size:11px;color:var(--color-text-secondary)}
.ftag strong{font-weight:600;color:var(--color-text-primary)}
.sep{color:var(--color-border-primary);margin:0 4px}
/* attribution footer */
.attribution{margin-top:18px;padding:12px 16px;border-radius:10px;background:var(--color-background-secondary);border:1px solid var(--color-border-tertiary);display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:8px}
.attr-left{display:flex;align-items:center;gap:6px;flex-wrap:wrap;font-size:12px;color:var(--color-text-secondary)}
.attr-left strong{font-weight:600;color:var(--color-text-primary);font-size:12px}
.attr-left a{color:#1D9E75;font-weight:600;text-decoration:none}
.attr-left a:hover{text-decoration:underline}
.attr-phone{display:inline-flex;align-items:center;gap:4px;background:#1D9E75;color:#fff;border-radius:20px;padding:2px 10px;font-size:11px;font-weight:600;text-decoration:none;white-space:nowrap}
.attr-phone:hover{background:#178a63}
.attr-right{font-size:11px;color:var(--color-text-secondary);display:flex;align-items:center;gap:4px;white-space:nowrap}
.attr-right .spark{color:#1D9E75;font-size:13px}
</style>

