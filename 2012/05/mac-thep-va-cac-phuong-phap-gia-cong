<script>
let activeSrc='all', activeGc='all';
function setSrc(val,btn){
  activeSrc=val;
  document.querySelectorAll('#src-bar .fbtn').forEach(b=>b.classList.remove('active-src'));
  btn.classList.add('active-src');
  applyFilter();
}
function setGc(val,btn){
  activeGc=val;
  document.querySelectorAll('#gc-bar .fbtn').forEach(b=>b.classList.remove('active-gc','active-src'));
  if(val==='all') btn.classList.add('active-src');
  else btn.classList.add('active-gc');
  applyFilter();
}
function applyFilter(){
  const rows=document.querySelectorAll('#steel-table tbody tr[data-src]');
  let visible=0,atp=0,vn=0,cn=0;
  rows.forEach(r=>{
    const srcOk=activeSrc==='all'||r.dataset.src===activeSrc;
    const gcOk =activeGc==='all'||(r.dataset.gc||'').split(' ').includes(activeGc);
    const show=srcOk&&gcOk;
    r.classList.toggle('hidden',!show);
    if(show){visible++;if(r.dataset.src==='atp')atp++;if(r.dataset.src==='vn')vn++;if(r.dataset.src==='cn')cn++;}
  });
  document.querySelectorAll('#steel-table tbody tr.group-hdr').forEach(g=>{
    let next=g.nextElementSibling,has=false;
    while(next&&!next.classList.contains('group-hdr')){if(!next.classList.contains('hidden')){has=true;break;}next=next.nextElementSibling;}
    g.classList.toggle('hidden',!has);
  });
  document.getElementById('visible-count').textContent=visible;
  document.getElementById('total-count').textContent=rows.length;
  document.getElementById('atp-count').textContent=atp;
  document.getElementById('vn-count').textContent=vn;
  document.getElementById('cn-count').textContent=cn;
  document.getElementById('no-result').style.display=visible===0?'block':'none';
}
applyFilter();
</script>
